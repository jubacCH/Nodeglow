{
  "$schema": "./tokens.schema.json",
  "_comment": "Single source of truth for Nodeglow design tokens. Run `npm run build:tokens` to regenerate src/styles/tokens.gen.{css,ts}. Both globals.css and tailwind.config.ts consume the generated files — never edit them by hand.",

  "color": {
    "dark": {
      "bg":             "#0B0E14",
      "surface":        "#111621",
      "elevated":       "#1A1F2E",
      "border":         "#1E2433",
      "primary":        "#38BDF8",
      "accent":         "#A78BFA",
      "success":        "#34D399",
      "warning":        "#FBBF24",
      "critical":       "#F87171",
      "text-primary":   "#F1F5F9",
      "text-secondary": "#94A3B8",
      "text-muted":     "#64748B"
    },
    "light": {
      "bg":             "#E8EEF4",
      "surface":        "#EFF4F8",
      "elevated":       "#F4F7FA",
      "border":         "#CBD5E1",
      "primary":        "#0284C7",
      "accent":         "#7C3AED",
      "success":        "#059669",
      "warning":        "#D97706",
      "critical":       "#DC2626",
      "text-primary":   "#0F172A",
      "text-secondary": "#334155",
      "text-muted":     "#64748B"
    }
  },

  "radius": {
    "card":   "16px",
    "button":  "8px",
    "pill":  "9999px"
  },

  "font": {
    "sans": "var(--font-inter), system-ui, sans-serif",
    "mono": "var(--font-mono), monospace"
  }
}
