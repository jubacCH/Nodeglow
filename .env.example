# Nodeglow environment configuration
# Copy to .env and adjust values

# PostgreSQL (used by docker compose)
POSTGRES_DB=nodeglow
POSTGRES_USER=nodeglow
POSTGRES_PASSWORD=changeme

# App database URL (set automatically by docker compose)
# For SQLite (default if not set): leave empty
# For PostgreSQL: postgresql+asyncpg://nodeglow:changeme@db:5432/nodeglow
DATABASE_URL=postgresql+asyncpg://nodeglow:${POSTGRES_PASSWORD}@db:5432/nodeglow

# Secret key for Fernet credential encryption + HMAC pepper.
# Recommended: generate once with `openssl rand -hex 32` and set it here so
# the key lives OUTSIDE the data volume. If left empty the backend
# auto-generates one inside /data/.secret_key and logs a warning.
#
# Migrating an EXISTING deployment from file-based key to env-based key:
#   1. Stop the backend container
#   2. Read the current file value:  docker compose run --rm nodeglow cat /data/.secret_key
#   3. Paste it verbatim into SECRET_KEY below (value must be IDENTICAL —
#      setting a different SECRET_KEY will render all existing encrypted
#      credentials unreadable)
#   4. Start the backend, verify it logs no warning about volume-loaded keys
#   5. Delete /data/.secret_key from the volume
# SECRET_KEY=

# Data directory (for SQLite DB + secret key file)
# DATA_DIR=/data

# Legacy escape hatch for the pre-install-token agent enrollment flow.
# Set to "1" ONLY if you still have existing agents that re-enroll using the
# shared agent_enrollment_key. Leave unset on fresh deployments — new agents
# must use per-install tokens minted via POST /api/agents/install-tokens.
# NODEGLOW_ALLOW_SHARED_ENROLLMENT=

# Shared bearer token between backend and updater sidecar.
# Required — without it the updater rejects every mutating request (fail-closed).
# Generate with:  openssl rand -hex 32
# Rotation: generate a new value, update .env in both containers' environment,
# then `docker compose up -d nodeglow updater` to reload them together.
UPDATE_SIDECAR_TOKEN=changeme-generate-with-openssl-rand-hex-32
