<clickhouse>
    <!-- Homelab-friendly memory limits. Increase for larger deployments. -->
    <max_server_memory_usage_to_ram_ratio>0.3</max_server_memory_usage_to_ram_ratio>
    <mark_cache_size>268435456</mark_cache_size>
    <uncompressed_cache_size>536870912</uncompressed_cache_size>
    <max_concurrent_queries>20</max_concurrent_queries>
    <logger>
        <level>warning</level>
    </logger>
</clickhouse>
