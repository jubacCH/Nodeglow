<clickhouse>
    <!-- Homelab-friendly memory limits. Increase for larger deployments. -->
    <max_server_memory_usage_to_ram_ratio>0.3</max_server_memory_usage_to_ram_ratio>
    <mark_cache_size>268435456</mark_cache_size>
    <uncompressed_cache_size>536870912</uncompressed_cache_size>
    <max_concurrent_queries>20</max_concurrent_queries>
    <logger>
        <level>warning</level>
    </logger>

    <!-- TTL on system log tables to prevent disk exhaustion -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </query_log>
    <processors_profile_log>
        <database>system</database>
        <table>processors_profile_log</table>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </processors_profile_log>
    <trace_log>
        <database>system</database>
        <table>trace_log</table>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </trace_log>
    <metric_log>
        <database>system</database>
        <table>metric_log</table>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </metric_log>
    <asynchronous_metric_log>
        <database>system</database>
        <table>asynchronous_metric_log</table>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </asynchronous_metric_log>
</clickhouse>
